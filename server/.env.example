# ===== 必填项 =====

# 腾讯地图 WebService API Key
# 申请地址: https://lbs.qq.com/dev/console/application/mine
# 未配置时服务仍可启动，但地图 geocode 接口会返回 500
TENCENT_MAP_KEY=YOUR_KEY_HERE

# ===== 可选项（有默认值） =====

# 服务监听端口
PORT=3001

# SQLite 数据库文件路径（相对于 server 根目录）
# 首次启动会自动创建文件及目录
DB_PATH=data/app.db

# 跨域允许的来源 origin
# 留空或不设置则允许所有来源（适合小程序本地调试）
# 生产环境建议设置为实际域名，如 https://example.com
# CORS_ORIGIN=https://example.com
