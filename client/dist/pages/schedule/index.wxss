.schedule-page{background:#f5f6fa;height:100vh}.loading-wrap{-ms-flex-pack:center;-ms-flex-align:center;-webkit-align-items:center;align-items:center;color:#999;display:-webkit-flex;display:-ms-flexbox;display:flex;font-size:28rpx;height:400rpx;-webkit-justify-content:center;justify-content:center}.schedule-list{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh}.schedule-list-inner{padding:30rpx 24rpx}.schedule-card{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:row;-ms-flex-direction:row;flex-direction:row;margin-bottom:8rpx}.schedule-timeline{-ms-flex-align:center;-ms-flex-negative:0;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-flex-shrink:0;flex-shrink:0;padding-top:8rpx;width:48rpx}.timeline-dot{-ms-flex-negative:0;background:-webkit-linear-gradient(315deg,#667eea,#764ba2);background:linear-gradient(135deg,#667eea,#764ba2);border-radius:50%;-webkit-flex-shrink:0;flex-shrink:0;height:20rpx;width:20rpx}.timeline-line{background:#e0e0e0;-webkit-flex:1;-ms-flex:1;flex:1;margin-top:4rpx;width:4rpx}.schedule-content{background:#fff;border-radius:16rpx;-webkit-box-shadow:0 4rpx 12rpx rgba(0,0,0,.05);box-shadow:0 4rpx 12rpx rgba(0,0,0,.05);-webkit-flex:1;-ms-flex:1;flex:1;margin-bottom:20rpx;overflow:hidden}.schedule-date-tag{background:-webkit-linear-gradient(315deg,#667eea,#764ba2);background:linear-gradient(135deg,#667eea,#764ba2);border-radius:0 0 12rpx 0;color:#fff;display:inline-block;font-size:22rpx;padding:6rpx 20rpx}.schedule-img{height:280rpx;width:100%}.schedule-text{padding:20rpx 24rpx}.schedule-title{color:#333;display:block;font-size:30rpx;font-weight:700;margin-bottom:8rpx}.schedule-desc{color:#888;display:block;font-size:24rpx;line-height:1.6}