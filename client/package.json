{
  "name": "client",
  "version": "1.0.0",
  "private": true,
  "description": "特产+日程+地图微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5 && node ./scripts/write-h5-index.mjs",
    "dev:h5": "taro build --type h5 --watch",
    "preview:h5": "npm run build:h5 && python3 -m http.server 10086 --directory dist",
    "test:mini:automator": "node ./scripts/run-miniprogram-automator-smoke.cjs",
    "test": "vitest run"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/components": "3.6.35",
    "@tarojs/helper": "3.6.35",
    "@tarojs/plugin-platform-h5": "^3.6.35",
    "@tarojs/plugin-platform-weapp": "3.6.35",
    "@tarojs/react": "^3.6.35",
    "@tarojs/runtime": "3.6.35",
    "@tarojs/shared": "3.6.35",
    "@tarojs/taro": "3.6.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "3.6.35",
    "@tarojs/plugin-framework-react": "3.6.35",
    "@tarojs/webpack5-runner": "3.6.35",
    "@types/react": "^18.0.0",
    "babel-preset-taro": "3.6.35",
    "miniprogram-automator": "^0.12.1",
    "react-refresh": "^0.18.0",
    "sass": "^1.56.0",
    "typescript": "^4.9.0",
    "vitest": "^4.1.8",
    "webpack": "5.78.0"
  }
}
